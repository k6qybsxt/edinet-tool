&lt;span style="font-family: &amp;apos;MS Mincho&amp;apos;; font-size: 12px; font-weight: normal"&gt;(258)&lt;/span&gt;
&lt;/p&gt;
&lt;/td&gt;
&lt;td style="border-top: 1px solid #000000; border-right: 1px solid #000000; border-bottom: 1px solid #000000; vertical-align: middle"&gt;
&lt;p style="margin-right: 12px; text-align: right"&gt;
