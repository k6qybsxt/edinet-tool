&lt;p style="line-height: 21.3333339691162px; text-align: center"&gt;
&lt;span style="font-size: 12px"&gt;＋&lt;/span&gt;
&lt;/p&gt;
&lt;/td&gt;
&lt;td colspan="3" style="border-left: 1px none #000000; border-top: 1px solid #000000; border-right: 1px none #000000; border-bottom: 1px none #000000; vertical-align: top"&gt;
