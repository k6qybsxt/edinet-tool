&lt;p style="line-height: 13.333333333333333333333333333px; text-align: center"&gt;（百万円）&lt;/p&gt;
&lt;/td&gt;
&lt;td style="vertical-align: middle; width: 88px; padding-top: 0px; padding-bottom: 0px; padding-left: 0px; padding-right: 0px; border-left: 1px solid #000000; border-top: 1px solid #000000; border-right: 1px solid #000000; border-bottom: 1px solid #000000"&gt;
&lt;p style="line-height: 13.333333333333333333333333333px; text-align: center"&gt;資本金残高&lt;/p&gt;
&lt;p style="line-height: 13.333333333333333333333333333px; text-align: center"&gt;（百万円）&lt;/p&gt;
&lt;/td&gt;
&lt;td style="vertical-align: middle; width: 88px; padding-top: 0px; padding-bottom: 0px; padding-left: 0px; padding-right: 0px; border-left: 1px solid #000000; border-top: 1px solid #000000; border-right: 1px solid #000000; border-bottom: 1px solid #000000"&gt;
&lt;p style="margin-left: 6px; line-height: 13.333333333333333333333333333px; margin-right: 6px; text-align: left"&gt;資本準備金増減額&lt;/p&gt;
&lt;p style="line-height: 13.333333333333333333333333333px; text-align: center"&gt;（百万円）&lt;/p&gt;
