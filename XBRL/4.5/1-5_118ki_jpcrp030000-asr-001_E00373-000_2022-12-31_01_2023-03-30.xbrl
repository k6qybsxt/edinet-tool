  <jpcrp_cor:DateOfResolutionDividendsOfSurplus contextRef="FilingDateInstant_Row1Member">2022-08-04</jpcrp_cor:DateOfResolutionDividendsOfSurplus>
  <jpcrp_cor:ResolutionDividendsOfSurplus contextRef="FilingDateInstant_Row1Member">取締役会決議</jpcrp_cor:ResolutionDividendsOfSurplus>
