&lt;p style="text-align: justify; text-justify: inter-ideograph"&gt;年額&lt;/p&gt;
&lt;/td&gt;
&lt;td style="vertical-align: top; width: 51px; padding-top: 0px; padding-bottom: 0px; padding-left: 0px; padding-right: 0px; border-left: 0px none ; border-top: 0px none ; border-right: 0px none ; border-bottom: 0px none "&gt;
